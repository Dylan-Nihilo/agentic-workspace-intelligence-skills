{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-fact-graph.schema.json",
  "type": "object",
  "required": ["schemaVersion", "version", "repoId", "analyzedAt", "nodes", "edges", "openQuestions", "stats"],
  "properties": {
    "schemaVersion": { "const": "repo-fact-graph/v1" },
    "version": { "const": "1.0" },
    "repoId": { "type": "string" },
    "analyzedAt": { "type": "string" },
    "nodes": { "type": "object" },
    "edges": { "type": "object" },
    "openQuestions": { "type": "array" },
    "stats": { "type": "object" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-incremental-plan.schema.json",
  "type": "object",
  "required": ["schemaVersion", "mode", "base", "changedFiles", "invalidatedNodeIds", "relatedEdgeIds", "newRepoId"],
  "properties": {
    "schemaVersion": { "const": "repo-incremental-plan/v1" },
    "mode": { "enum": ["affected-subgraph", "full-bootstrap"] },
    "base": { "type": "string" },
    "changedFiles": { "type": "array", "items": { "type": "string" } },
    "invalidatedNodeIds": { "type": "array", "items": { "type": "string" } },
    "relatedEdgeIds": { "type": "array", "items": { "type": "string" } },
    "previousRepoId": { "type": ["string", "null"] },
    "newRepoId": { "type": "string" },
    "reusedNodeCount": { "type": "number" },
    "reusedEdgeCount": { "type": "number" },
    "rescannedFileCount": { "type": "number" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-adversarial-verification.schema.json",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "checkedEdges", "confirmedEdges", "removedEdges", "skippedEdges", "verdicts"],
  "properties": {
    "schemaVersion": { "const": "repo-adversarial-verification/v1" },
    "generatedAt": { "type": "string" },
    "checkedEdges": { "type": "number" },
    "confirmedEdges": { "type": "number" },
    "removedEdges": { "type": "number" },
    "skippedEdges": { "type": "number" },
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["edgeId", "verdict", "reason"],
        "properties": {
          "edgeId": { "type": "string" },
          "verdict": { "enum": ["not-refuted", "refuted", "skipped"] },
          "reason": { "type": "string" },
          "evidenceChecked": { "type": "number" }
        }
      }
    }
  }
}

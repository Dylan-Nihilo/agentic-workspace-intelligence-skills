{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-render-graph.schema.json",
  "type": "object",
  "required": ["schemaVersion", "version", "repoId", "nodes", "edges", "groups", "views", "drilldown"],
  "properties": {
    "schemaVersion": { "const": "repo-render-graph/v1" },
    "version": { "const": "1.0" },
    "repoId": { "type": "string" },
    "nodes": { "type": "array" },
    "edges": { "type": "array" },
    "groups": { "type": "array" },
    "views": { "type": "array" },
    "drilldown": { "type": "object" }
  }
}

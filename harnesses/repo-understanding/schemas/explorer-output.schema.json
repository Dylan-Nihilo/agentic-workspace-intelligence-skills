{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-explorer-output.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "strategy",
    "facts",
    "openQuestions",
    "observations",
    "requestedEvidence",
    "gaps"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "repo-exploration-analysis/v1" },
    "strategy": { "type": "string" },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subject",
          "subjectType",
          "predicate",
          "object",
          "objectType",
          "source",
          "confidence",
          "explorer",
          "evidence"
        ],
        "properties": {
          "subject": { "type": "string" },
          "subjectType": { "type": "string" },
          "predicate": {
            "type": "string",
            "enum": [
              "imports",
              "dynamic-imports",
              "contains",
              "depends-on",
              "routes-to",
              "registers",
              "calls",
              "guarded-by",
              "reads-from",
              "writes-to",
              "extends",
              "implements"
            ]
          },
          "object": { "type": "string" },
          "objectType": { "type": "string" },
          "source": { "type": "string", "enum": ["dynamic", "inferred"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "explorer": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file", "line", "endLine", "snippet", "tool", "rawConfidence"],
              "properties": {
                "file": { "type": "string" },
                "line": { "type": "integer", "minimum": 1 },
                "endLine": { "type": "integer", "minimum": 1 },
                "snippet": { "type": "string" },
                "tool": { "type": "string" },
                "rawConfidence": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "relatedNodes", "raisedBy"],
        "properties": {
          "question": { "type": "string" },
          "relatedNodes": { "type": "array", "items": { "type": "string" } },
          "raisedBy": { "type": "string" }
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "finding", "confidence", "tags", "evidence"],
        "properties": {
          "title": { "type": "string" },
          "finding": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "startLine", "endLine", "reason"],
              "properties": {
                "path": { "type": "string" },
                "startLine": { "type": "integer", "minimum": 1 },
                "endLine": { "type": "integer", "minimum": 1 },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "requestedEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "searches"],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "reason", "ranges"],
            "properties": {
              "path": { "type": "string" },
              "reason": { "type": "string" },
              "ranges": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["startLine", "endLine", "label"],
                  "properties": {
                    "startLine": { "type": "integer", "minimum": 1 },
                    "endLine": { "type": "integer", "minimum": 1 },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "searches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "regex", "paths", "reason", "maxResults"],
            "properties": {
              "pattern": { "type": "string" },
              "regex": { "type": "boolean" },
              "paths": { "type": "array", "items": { "type": "string" } },
              "reason": { "type": "string" },
              "maxResults": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "gaps": { "type": "array", "items": { "type": "string" } }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-knowledge-chunk.schema.json",
  "type": "object",
  "required": ["id", "kind", "text", "graphRefs", "evidenceRefs", "metadata"],
  "properties": {
    "id": { "type": "string" },
    "kind": { "enum": ["fact", "symbol-card", "module-card"] },
    "text": { "type": "string" },
    "graphRefs": { "type": "array", "items": { "type": "string" } },
    "evidenceRefs": { "type": "array" },
    "metadata": { "type": "object" }
  }
}

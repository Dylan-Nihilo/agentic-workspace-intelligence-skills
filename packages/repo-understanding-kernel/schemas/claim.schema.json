{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim.schema.json",
  "type": "object",
  "required": ["schemaVersion", "claimId", "snapshotId", "subject", "predicate", "object", "qualifiers", "evidenceIds", "derivation", "status", "confidence", "riskClass", "verification", "supersedes", "supersededBy", "createdAt"],
  "properties": {
    "schemaVersion": { "const": "repo-claim/v2" },
    "claimId": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "predicate": { "type": "string", "minLength": 1 },
    "object": {},
    "qualifiers": { "type": "object" },
    "evidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "derivation": { "enum": ["deterministic", "agent"] },
    "status": { "enum": ["proposed", "accepted", "refuted", "superseded"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "riskClass": { "enum": ["low", "medium", "high", "critical"] },
    "createdByItemId": { "type": ["string", "null"] },
    "verification": { "type": "array" },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "supersededBy": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "minLength": 1 }
  }
}

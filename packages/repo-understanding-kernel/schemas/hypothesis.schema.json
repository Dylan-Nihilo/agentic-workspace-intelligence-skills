{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-hypothesis.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "hypothesisId",
    "contractId",
    "questionId",
    "statement",
    "subject",
    "predicate",
    "object",
    "hypothesisType",
    "supportEvidenceIds",
    "counterEvidenceIds",
    "qualifiers",
    "confidence",
    "status",
    "impact",
    "followUpQuestionIds"
  ],
  "properties": {
    "schemaVersion": { "const": "repo-hypothesis/v1" },
    "hypothesisId": { "type": "string", "minLength": 1 },
    "contractId": { "type": "string", "minLength": 1 },
    "questionId": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "predicate": { "type": "string", "minLength": 1 },
    "object": {},
    "hypothesisType": { "type": "string", "minLength": 1 },
    "supportEvidenceIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "counterEvidenceIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "qualifiers": { "type": "object" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "enum": ["proposed", "supported", "refuted", "inconclusive"] },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapDimensions", "journeyIds"],
      "properties": {
        "mapDimensions": {
          "type": "array",
          "items": {
            "enum": [
              "application-bootstrap",
              "route-layout-page",
              "component-composition",
              "state-ownership-data-flow",
              "api-client",
              "auth-permission",
              "build-deploy",
              "testing-quality",
              "core-journeys"
            ]
          }
        },
        "journeyIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "followUpQuestionIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}

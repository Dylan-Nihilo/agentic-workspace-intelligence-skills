{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-work-item.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "itemId",
    "runId",
    "snapshotId",
    "attempt",
    "kind",
    "role",
    "contractRef",
    "objectiveSummary",
    "blocking",
    "dependencies",
    "completionPolicyRef",
    "inputArtifactRefs",
    "outputArtifactPath",
    "outputSchemaRef",
    "communityIds",
    "neighborMapRef",
    "blockingMapDimensions",
    "blockingJourneyIds",
    "qualityClass",
    "criticality",
    "budgetHints",
    "idempotencyKey",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "const": "repo-work-item/v3" },
    "itemId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1 },
    "kind": { "enum": ["semantic-research", "adjudicate", "synthesize"] },
    "role": { "type": "string", "minLength": 1 },
    "contractRef": { "type": "string", "minLength": 1 },
    "objectiveSummary": { "type": "string", "minLength": 1 },
    "blocking": { "type": "boolean" },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "completionPolicyRef": { "type": "string", "minLength": 1 },
    "inputArtifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "outputArtifactPath": { "type": "string", "minLength": 1 },
    "outputSchemaRef": { "type": "string", "minLength": 1 },
    "communityIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "neighborMapRef": { "type": ["string", "null"] },
    "blockingMapDimensions": {
      "type": "array",
      "items": {
        "enum": [
          "application-bootstrap",
          "route-layout-page",
          "component-composition",
          "state-ownership-data-flow",
          "api-client",
          "auth-permission",
          "build-deploy",
          "testing-quality",
          "core-journeys"
        ]
      }
    },
    "blockingJourneyIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "qualityClass": { "enum": ["routine", "analytical", "critical"] },
    "criticality": { "enum": ["low", "medium", "high", "critical"] },
    "budgetHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxFiles": { "type": "integer", "minimum": 1 },
        "maxContextBytes": { "type": "integer", "minimum": 1 },
        "maxOutputBytes": { "type": "integer", "minimum": 1 },
        "maxTokens": { "type": "integer", "minimum": 1 },
        "maxDurationMs": { "type": "integer", "minimum": 1 }
      }
    },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "retryOf": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-experience-map.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mapId",
    "snapshotId",
    "projectionKey",
    "journeys",
    "semanticClaims",
    "blockedDimensions",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "repo-experience-map/v1" },
    "mapId": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "projectionKey": { "$ref": "repo-product-map-common.schema.json#/$defs/projectionKey" },
    "journeys": {
      "type": "array",
      "items": { "$ref": "repo-journey-definition.schema.json" }
    },
    "semanticClaims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claimId", "subject", "predicate", "object", "evidenceIds", "confidence", "qualifiers"],
        "properties": {
          "claimId": { "type": "string", "minLength": 1 },
          "subject": { "type": "string", "minLength": 1 },
          "predicate": { "type": "string", "minLength": 1 },
          "object": {},
          "evidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "qualifiers": { "type": "object" }
        }
      }
    },
    "blockedDimensions": { "type": "array", "items": { "$ref": "repo-product-map-common.schema.json#/$defs/blockedDimension" } },
    "generatedAt": { "type": "string", "minLength": 1 }
  }
}

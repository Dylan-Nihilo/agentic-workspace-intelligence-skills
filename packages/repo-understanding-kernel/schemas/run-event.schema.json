{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-run-event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "runId",
    "sequence",
    "eventType",
    "occurredAt",
    "actor",
    "payload",
    "previousEventHash",
    "eventHash"
  ],
  "properties": {
    "schemaVersion": { "const": "repo-run-event/v3" },
    "eventId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "eventType": {
      "enum": [
        "run-created",
        "snapshot-created",
        "support-decided",
        "census-completed",
        "static-graph-built",
        "investigation-frame-built",
        "research-contracted",
        "work-planned",
        "work-issued",
        "result-detected",
        "result-accepted",
        "result-rejected",
        "task-outcome-accepted",
        "task-outcome-rejected",
        "work-abandoned",
        "work-waived",
        "question-qualified",
        "question-planned",
        "question-resolved",
        "question-blocked",
        "question-invalidated",
        "hypothesis-supported",
        "hypothesis-refuted",
        "claim-accepted",
        "claim-refuted",
        "journey-closed",
        "journey-reopened",
        "verification-passed",
        "verification-failed",
        "synthesis-accepted",
        "projection-built",
        "run-unsupported",
        "run-blocked",
        "run-completed"
      ]
    },
    "occurredAt": { "type": "string", "format": "date-time" },
    "actor": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "previousEventHash": { "type": ["string", "null"] },
    "eventHash": { "type": "string", "minLength": 1 }
  }
}

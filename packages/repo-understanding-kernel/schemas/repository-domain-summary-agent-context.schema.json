{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-repository-domain-summary-agent-context/v1",
  "type": "object",
  "required": ["schemaVersion", "planId", "graphId", "snapshotId", "semanticCatalogHash", "zonePlanId", "zoneCatalogHash", "repo", "summary", "zones", "analysisRequirements", "resultContract", "generatedAt"],
  "properties": {
    "schemaVersion": { "const": "repo-repository-domain-summary-agent-context/v1" },
    "planId": { "type": "string", "minLength": 1 },
    "graphId": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "semanticCatalogHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "zonePlanId": { "type": "string", "minLength": 1 },
    "zoneCatalogHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "repo": { "type": "object" },
    "summary": { "type": "object" },
    "zones": { "type": "array", "minItems": 1 },
    "analysisRequirements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "resultContract": { "type": "object" },
    "generatedAt": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}

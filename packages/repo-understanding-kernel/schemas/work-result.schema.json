{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-work-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "itemId",
    "runId",
    "snapshotId",
    "attempt",
    "contractId",
    "status",
    "outcomeStatus",
    "completionSummary",
    "producer",
    "artifactHashes",
    "readSet",
    "scopeViolations",
    "errors",
    "producedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "repo-work-result/v3" },
    "itemId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "snapshotId": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1 },
    "contractId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["completed", "failed", "blocked"] },
    "outcomeStatus": { "enum": ["satisfied", "partially-satisfied", "blocked", "failed"] },
    "completionSummary": { "type": "string", "minLength": 1 },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "schemaVersion"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string", "minLength": 1 }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "usage"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string" },
        "model": { "type": "string" },
        "effort": { "type": "string" },
        "sessionId": { "type": "string" },
        "usage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["reported", "unavailable"] },
            "inputTokens": { "type": "integer", "minimum": 0 },
            "outputTokens": { "type": "integer", "minimum": 0 },
            "cachedInputTokens": { "type": "integer", "minimum": 0 },
            "reasoningTokens": { "type": "integer", "minimum": 0 },
            "totalTokens": { "type": "integer", "minimum": 0 },
            "costUsd": { "type": "number", "minimum": 0 },
            "durationMs": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "artifactHashes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifactRef", "algorithm", "value"],
        "properties": {
          "artifactRef": { "type": "string", "minLength": 1 },
          "algorithm": { "const": "sha256" },
          "value": { "type": "string", "minLength": 64, "maxLength": 64 }
        }
      }
    },
    "readSet": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "fingerprintAlgorithm", "contentFingerprint", "structureFingerprint"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "fingerprintAlgorithm": { "const": "sha256" },
          "contentFingerprint": { "type": "string", "minLength": 64, "maxLength": 64 },
          "structureFingerprint": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^structure:sha256:[a-f0-9]{64}$" }
            ]
          }
        }
      }
    },
    "scopeViolations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 },
          "retryable": { "type": "boolean" }
        }
      }
    },
    "producedAt": { "type": "string", "minLength": 1 }
  }
}

{
  "name": "agentic-workspace-intelligence-skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/repo-understanding-kernel",
    "packages/repo-understanding-cli"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present && npm run eval:trajectory",
    "analyze:repo": "node scripts/code-repo-analyzer.mjs",
    "coding:collect": "node skills/agentic-coding-audit/scripts/collect-static.mjs",
    "coding:normalize": "node skills/agentic-coding-audit/scripts/normalize-coding-pool.mjs",
    "coding:export": "node skills/agentic-coding-audit/scripts/export-audit-data.mjs",
    "datasource:pipeline": "node skills/agentic-datasource-orchestrator/scripts/run-pipeline.mjs",
    "build:workspace-datasource": "node shared/scripts/build-workspace-datasource.mjs",
    "understanding:harness": "node packages/repo-understanding-cli/src/cli.mjs",
    "understanding:human-html": "node skills/repo-human-readable/scripts/generate-html.mjs",
    "eval:contract": "node evals/contract/run-contract.mjs",
    "eval:datasource": "node evals/run-all.mjs datasource",
    "eval:behavioral": "node evals/run-all.mjs behavioral",
    "eval:triggering": "node evals/run-all.mjs triggering",
    "eval:retrieval": "node evals/run-all.mjs retrieval",
    "eval:knowledge": "node evals/run-all.mjs knowledge",
    "eval:trajectory": "node evals/run-all.mjs trajectory",
    "eval:cost": "node evals/run-all.mjs cost",
    "eval:all": "node evals/run-all.mjs all"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
